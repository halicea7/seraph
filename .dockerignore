# Keep the build context small & secret-free.

# Python / venv
.venv/
venv/
env/
**/__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# The leftover web SPA is not bundled (Electron is the frontend) — don't ship it.
frontend/
**/node_modules/

# VCS & IDE
.git/
.gitignore
.vscode/
.idea/

# Secrets & local state (provided at runtime via env_file, never baked in)
.env
.env.*
!.env.example
certs/
*.pem
*.key
*.crt

# Databases & scan artifacts
*.db
*.sqlite
*.sqlite3
seraph_results/
*.log
logs/

# Repo docs not needed in the image
INTERVIEW_PREP.md
PLAN.md
README.md
docs/
