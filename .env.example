# Copy this file to .env and fill in your values.
# .env is gitignored and should never be committed.

# Required in production — long random string for JWT signing
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SERAPH_SECRET_KEY=

# Metasploit RPC password (set the same value when starting msfrpcd)
# Used by: dev.sh and the C2 module
MSF_RPC_PASSWORD=
