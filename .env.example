# Copy this file to .env and fill in your values.
# .env is gitignored and should never be committed.

# ── Required in production ──────────────────────────────────────────────────

# Long random string for JWT signing.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SERAPH_SECRET_KEY=

# PostgreSQL password (used by both the db service and the backend connection string).
# Only required when running docker-compose.prod.yml.
POSTGRES_PASSWORD=

# ── Metasploit RPC ──────────────────────────────────────────────────────────

# Password to authenticate against msfrpcd.
# Must match the value passed to: msfrpcd -P <password> -S -f
MSF_RPC_PASSWORD=

# ── Sliver C2 (optional) ─────────────────────────────────────────────────────

# Path to the Sliver operator config file inside the container.
# Mount the config via a Docker volume or secret if used.
# SLIVER_CONFIG=/run/secrets/sliver.cfg

# ── WebAuthn / Passkeys ──────────────────────────────────────────────────────

# Relying Party ID — must match the domain your browser sees (no port).
# Example: yourdomain.com
SERAPH_RP_ID=localhost

# Comma-separated list of allowed origins for WebAuthn and CORS.
# Default covers localhost dev; set to your production URLs in prod.
SERAPH_RP_ORIGINS=http://localhost:8000,https://localhost:8000,http://localhost:22123

# ── Rate limiting ────────────────────────────────────────────────────────────

# Max requests per window per IP (default: 300)
# SERAPH_RATE_LIMIT_REQUESTS=300

# Window size in seconds (default: 60)
# SERAPH_RATE_LIMIT_WINDOW=60

# ── Database ─────────────────────────────────────────────────────────────────

# SQLite (default, for local dev):
# SERAPH_DATABASE_URL=sqlite:///./seraph.db

# PostgreSQL (set automatically by docker-compose.prod.yml):
# SERAPH_DATABASE_URL=postgresql+psycopg2://seraph:<password>@db:5432/seraph

# ── Networking ───────────────────────────────────────────────────────────────

# Host port that nginx listens on in docker-compose.prod.yml (default: 8080)
# SERAPH_PORT=8080
