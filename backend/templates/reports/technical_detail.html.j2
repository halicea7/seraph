<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Technical Detail Report — {{ project_name }}</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', system-ui, sans-serif; background: #f8fafc; color: #1e293b; line-height: 1.6; }
  .page { max-width: 920px; margin: 0 auto; padding: 3rem 2rem; }
  .header { border-bottom: 4px solid #1e293b; padding-bottom: 1.5rem; margin-bottom: 2rem; }
  .header h1 { font-size: 2rem; font-weight: 700; color: #0f172a; }
  .header .subtitle { font-size: 0.95rem; color: #64748b; margin-top: 0.25rem; }
  .meta-row { display: flex; gap: 2rem; margin-bottom: 2rem; flex-wrap: wrap; }
  .meta-item .label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.05em; color: #94a3b8; }
  .meta-item .value { font-size: 0.9rem; font-weight: 600; color: #0f172a; }
  h2 { font-size: 1.1rem; font-weight: 700; color: #0f172a; margin: 2.5rem 0 1rem; border-bottom: 1px solid #e2e8f0; padding-bottom: 0.4rem; }
  h3 { font-size: 0.95rem; font-weight: 700; color: #1e293b; margin: 0.5rem 0; }
  .finding-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 10px; padding: 1.25rem 1.5rem; margin-bottom: 1rem; border-left: 4px solid #e2e8f0; }
  .finding-card.critical { border-left-color: #ef4444; }
  .finding-card.high     { border-left-color: #f97316; }
  .finding-card.medium   { border-left-color: #f59e0b; }
  .finding-card.low      { border-left-color: #22c55e; }
  .finding-card.info     { border-left-color: #3b82f6; }
  .finding-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.75rem; }
  .sev-badge { font-size: 0.7rem; font-weight: 700; padding: 0.2rem 0.6rem; border-radius: 4px; color: #fff; text-transform: uppercase; flex-shrink: 0; margin-left: 0.75rem; }
  .sev-badge.critical { background: #ef4444; }
  .sev-badge.high     { background: #f97316; }
  .sev-badge.medium   { background: #d97706; }
  .sev-badge.low      { background: #16a34a; }
  .sev-badge.info     { background: #2563eb; }
  .field-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em; color: #94a3b8; margin-top: 0.75rem; margin-bottom: 0.2rem; }
  .field-value { font-size: 0.875rem; color: #334155; }
  pre { background: #0f172a; color: #e2e8f0; font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; border-radius: 6px; padding: 0.75rem 1rem; overflow-x: auto; margin: 0.25rem 0; white-space: pre-wrap; word-break: break-all; }
  .cve-tag { display: inline-block; background: #eff6ff; border: 1px solid #bfdbfe; color: #1d4ed8; font-size: 0.75rem; font-weight: 600; padding: 0.1rem 0.5rem; border-radius: 4px; margin-right: 0.4rem; }
  .summary-table { width: 100%; border-collapse: collapse; margin-bottom: 2rem; font-size: 0.85rem; }
  .summary-table th { background: #f1f5f9; color: #475569; padding: 0.6rem 0.75rem; text-align: left; border: 1px solid #e2e8f0; }
  .summary-table td { padding: 0.6rem 0.75rem; border: 1px solid #e2e8f0; color: #334155; vertical-align: top; }
  .summary-table tr:nth-child(even) td { background: #f8fafc; }
  .footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid #e2e8f0; font-size: 0.75rem; color: #94a3b8; display: flex; justify-content: space-between; }
</style>
</head>
<body>
<div class="page">
  <!-- Header -->
  <div class="header">
    <h1>{{ project_name }}</h1>
    <div class="subtitle">Technical Detail Report &mdash; Security Assessment</div>
  </div>

  <!-- Meta -->
  <div class="meta-row">
    <div class="meta-item"><div class="label">Generated</div><div class="value">{{ generated_at }}</div></div>
    <div class="meta-item"><div class="label">Auditor</div><div class="value">{{ auditor }}</div></div>
    <div class="meta-item"><div class="label">Targets</div><div class="value">{{ targets | length }}</div></div>
    <div class="meta-item"><div class="label">Scans</div><div class="value">{{ scans | length }}</div></div>
    <div class="meta-item"><div class="label">Total Findings</div><div class="value">{{ total_findings }}</div></div>
    <div class="meta-item"><div class="label">Overall Risk</div><div class="value">{{ risk_rating }}</div></div>
  </div>

  <!-- Finding Summary Table -->
  <h2>Finding Summary</h2>
  <table class="summary-table">
    <thead>
      <tr><th>#</th><th>Severity</th><th>Title</th><th>CVE</th><th>CVSS</th></tr>
    </thead>
    <tbody>
      {% for f in findings %}
      <tr>
        <td>{{ loop.index }}</td>
        <td><span class="sev-badge {{ f.severity }}">{{ f.severity }}</span></td>
        <td>{{ f.title }}</td>
        <td>{% if f.cve_id %}<span class="cve-tag">{{ f.cve_id }}</span>{% else %}&mdash;{% endif %}</td>
        <td>{{ f.cvss_score if f.cvss_score else '&mdash;' }}</td>
      </tr>
      {% else %}
      <tr><td colspan="5" style="text-align:center;color:#94a3b8;">No findings recorded.</td></tr>
      {% endfor %}
    </tbody>
  </table>

  <!-- Detailed Finding Cards -->
  <h2>Detailed Findings</h2>
  {% for f in findings %}
  <div class="finding-card {{ f.severity }}">
    <div class="finding-header">
      <h3>{{ loop.index }}. {{ f.title }}</h3>
      <span class="sev-badge {{ f.severity }}">{{ f.severity }}</span>
    </div>

    {% if f.cve_id or f.cvss_score %}
    <div>
      {% if f.cve_id %}<span class="cve-tag">{{ f.cve_id }}</span>{% endif %}
      {% if f.cvss_score %}<span class="cve-tag">CVSS {{ f.cvss_score }}</span>{% endif %}
    </div>
    {% endif %}

    {% if f.description %}
    <div class="field-label">Description</div>
    <div class="field-value">{{ f.description }}</div>
    {% endif %}

    {% if f.remediation %}
    <div class="field-label">Remediation</div>
    <div class="field-value">{{ f.remediation }}</div>
    {% endif %}

    {% if f.evidence %}
    <div class="field-label">Evidence / Tool Output</div>
    <pre>{{ f.evidence }}</pre>
    {% endif %}

    {% if f.screenshots %}
    <div class="field-label">Screenshot Evidence</div>
    <div>
      {% for sh in f.screenshots %}
      <figure style="margin:0 0 12px;">
        <img src="{{ sh.data_uri }}" alt="{{ sh.url }}" style="max-width:100%;border:1px solid #ccc;" />
        <figcaption style="font-size:11px;color:#666;font-family:monospace;">{{ sh.url }}</figcaption>
      </figure>
      {% endfor %}
    </div>
    {% endif %}

    {% if f.control_id or f.framework %}
    <div class="field-label">Control Reference</div>
    <div class="field-value">
      {% if f.control_id %}{{ f.control_id }}{% endif %}
      {% if f.framework %} &mdash; {{ f.framework }}{% endif %}
    </div>
    {% endif %}
  </div>
  {% else %}
  <p style="color:#64748b;font-size:0.9rem;">No findings were recorded for this assessment.</p>
  {% endfor %}

  <!-- Scanned Targets -->
  <h2>Targets Assessed</h2>
  <table class="summary-table">
    <thead>
      <tr><th>Host / IP</th><th>Type</th><th>Notes</th></tr>
    </thead>
    <tbody>
      {% for t in targets %}
      <tr>
        <td>{{ t.hostname_or_ip }}</td>
        <td>{{ t.target_type }}</td>
        <td>{{ t.notes or '&mdash;' }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

  <div class="footer">
    <span>{{ project_name }} &mdash; Technical Detail</span>
    <span>Generated {{ generated_at }} &middot; {{ generated_by }}</span>
  </div>
</div>
</body>
</html>
